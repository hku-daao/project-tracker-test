# Copy to .env and fill in real values. Do not commit .env.

# Optional: comma-separated extra allowed browser origins (Flutter web). Defaults include Firebase Hosting URLs.
# CORS_ORIGINS=https://my-custom-domain.example.com

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Firebase service account JSON as a single line (Project Settings → Service accounts → Generate new private key)
# Paste the entire JSON object here (one line, no line breaks).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"daao-a20c6",...}
